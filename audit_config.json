{
  "config_version": "1.0",
  "organisation": "Enterprise AI Division",
  "regulatory_framework": "EU AI Act + Internal AI Governance Policy v2.1",
  "risk_tiers": {
    "L1": {
      "label": "Low Risk",
      "description": "Informational outputs with no decision impact",
      "approval_required": false,
      "human_review_required": false,
      "monitoring_frequency": "weekly"
    },
    "L2": {
      "label": "Medium Risk",
      "description": "Outputs influencing business decisions or customer interactions",
      "approval_required": true,
      "human_review_required": true,
      "monitoring_frequency": "daily"
    },
    "L3": {
      "label": "High Risk",
      "description": "Outputs with regulatory, financial or safety implications",
      "approval_required": true,
      "human_review_required": true,
      "monitoring_frequency": "real_time"
    }
  },
  "compliance_checks": {
    "content_safety": {
      "enabled": true,
      "weight": 0.25,
      "prohibited_patterns": [
        "guaranteed returns",
        "risk-free investment",
        "100% accurate",
        "no side effects",
        "clinically proven without citation",
        "legal advice",
        "medical diagnosis"
      ]
    },
    "data_privacy": {
      "enabled": true,
      "weight": 0.20,
      "pii_patterns": [
        "\\b[A-Z]{5}[0-9]{4}[A-Z]{1}\\b",
        "\\b[0-9]{12}\\b",
        "\\b[0-9]{10}\\b",
        "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Z|a-z]{2,}\\b"
      ]
    },
    "factual_grounding": {
      "enabled": true,
      "weight": 0.25,
      "hallucination_markers": [
        "studies show", "research proves", "experts confirm",
        "it is well established", "universally accepted",
        "always", "never", "guaranteed", "100%"
      ]
    },
    "transparency": {
      "enabled": true,
      "weight": 0.15,
      "required_disclosures": [
        "ai generated",
        "generated by",
        "this is an ai",
        "artificial intelligence",
        "automated response",
        "please verify",
        "consult a professional"
      ]
    },
    "bias_indicators": {
      "enabled": true,
      "weight": 0.15,
      "bias_patterns": [
        "all women", "all men", "all indians", "all muslims",
        "all christians", "typically for men", "typically for women",
        "naturally better at", "inherently"
      ]
    }
  },
  "severity_thresholds": {
    "critical": 40,
    "high": 60,
    "medium": 75,
    "low": 90
  },
  "retention_policy_days": 90
}
